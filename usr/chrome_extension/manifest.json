{
  "manifest_version": 3,
  "name": "English to Arabic Converter",
  "version": "1.0",
  "description": "Converts selected English text to Arabic characters using Alt+R.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end",
      "all_frames": true
    }
  ]
}
